[Unit]
Description=Hudud Live Report Validation API
After=network.target

[Service]
Type=simple
WorkingDirectory=/var/www/hudud.live-app
Environment=PORT=8787
Environment=GEMINI_MODEL=gemini-2.5-flash
Environment=GEMINI_API_KEY=PUT_YOUR_KEY_HERE
ExecStart=/usr/bin/node /var/www/hudud.live-app/server/report-validation-server.mjs
Restart=always
RestartSec=3
User=www-data
Group=www-data

[Install]
WantedBy=multi-user.target
